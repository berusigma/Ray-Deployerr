{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/s/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/admin(.*)",
      "dest": "/public/admin.html"
    },
    {
      "src": "/dashboard(.*)",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/filemanager(.*)",
      "dest": "/public/filemanager.html"
    },
    {
      "src": "/login",
      "dest": "/public/login.html"
    },
    {
      "src": "/register",
      "dest": "/public/register.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    }
  ]
}
